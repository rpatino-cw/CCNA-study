{
  "_doc": "Jeremy's IT Lab Free CCNA v1.1 → CCNA 200-301 domain/sub-objective mapping. Playlist: PLxbwE86jKRgMpuZuLBivzlM8s2Dk5lXBQ",
  "domains": {
    "1.0": {
      "name": "Network Fundamentals",
      "weight": "20%",
      "subtopics": {
        "1.1": "Explain the role and function of network components",
        "1.2": "Describe characteristics of network topology architectures",
        "1.3": "Compare physical interface and cabling types",
        "1.4": "Identify interface and cable issues",
        "1.5": "Compare TCP to UDP",
        "1.6": "Configure and verify IPv4 addressing and subnetting",
        "1.7": "Describe the need for private IPv4 addressing",
        "1.8": "Configure and verify IPv6 addressing and prefix",
        "1.9": "Describe IPv6 address types",
        "1.10": "Verify IP parameters for Client OS (Windows, Mac OS, Linux)",
        "1.11": "Describe wireless principles",
        "1.12": "Explain virtualization fundamentals (server, containers, VRFs)",
        "1.13": "Describe switching concepts"
      }
    },
    "2.0": {
      "name": "Network Access",
      "weight": "20%",
      "subtopics": {
        "2.1": "Configure and verify VLANs (normal range) spanning multiple switches",
        "2.2": "Configure and verify interswitch connectivity (trunks, DTP, 802.1Q, native VLAN)",
        "2.3": "Configure and verify Layer 2 discovery protocols (CDP, LLDP)",
        "2.4": "Configure and verify EtherChannel (LACP)",
        "2.5": "Interpret basic operations of Spanning Tree Protocols (RSTP, PVST+, PortFast, BPDU Guard, root/secondary bridge)",
        "2.6": "Describe Cisco Wireless Architectures and AP modes",
        "2.7": "Describe physical infrastructure connections of WLAN components (AP, WLC, access/trunk ports, LAG)",
        "2.8": "Describe AP/WLC management access connections (Telnet, SSH, HTTP, HTTPS, console, TACACS+/RADIUS, Cloud-managed)",
        "2.9": "Interpret the wireless LAN GUI configuration for client connectivity (WLAN creation, security, QoS, advanced WLAN settings)"
      }
    },
    "3.0": {
      "name": "IP Connectivity",
      "weight": "25%",
      "subtopics": {
        "3.1": "Interpret the components of a routing table",
        "3.2": "Determine how a router makes a forwarding decision by default",
        "3.3": "Configure and verify IPv4 and IPv6 static routing",
        "3.4": "Configure and verify single-area OSPFv2",
        "3.5": "Describe the purpose, functions, and concepts of first hop redundancy protocols (FHRP/HSRP)"
      }
    },
    "4.0": {
      "name": "IP Services",
      "weight": "10%",
      "subtopics": {
        "4.1": "Configure and verify inside source NAT using static and pools",
        "4.2": "Configure and verify NTP operating in client and server mode",
        "4.3": "Explain the role of DHCP and DNS within the network",
        "4.4": "Explain the function of SNMP in network operations",
        "4.5": "Describe the use of syslog features including facilities and severity levels",
        "4.6": "Configure and verify DHCP client and relay",
        "4.7": "Explain the forwarding per-hop behavior (PHB) for QoS (classification, marking, queuing, congestion, policing, shaping)",
        "4.8": "Configure network devices for remote access using SSH",
        "4.9": "Describe the capabilities and function of TFTP/FTP in the network"
      }
    },
    "5.0": {
      "name": "Security Fundamentals",
      "weight": "15%",
      "subtopics": {
        "5.1": "Define key security concepts (threats, vulnerabilities, exploits, mitigation techniques)",
        "5.2": "Describe security program elements (user awareness, training, physical access control)",
        "5.3": "Configure and verify device access control using local passwords",
        "5.4": "Describe security password policies elements (management, complexity, alternatives such as multifactor auth, certificates, biometrics)",
        "5.5": "Describe IPsec remote access and site-to-site VPNs",
        "5.6": "Configure and verify access control lists (standard and extended ACLs)",
        "5.7": "Configure and verify Layer 2 security features (DHCP snooping, dynamic ARP inspection, port security)",
        "5.8": "Compare authentication, authorization, and accounting (AAA) concepts",
        "5.9": "Describe wireless security protocols (WPA, WPA2, WPA3)",
        "5.10": "Configure and verify WLAN within the GUI using WPA2 PSK"
      }
    },
    "6.0": {
      "name": "Automation and Programmability",
      "weight": "10%",
      "subtopics": {
        "6.1": "Explain how automation impacts network management",
        "6.2": "Compare traditional networks with controller-based networking",
        "6.3": "Describe controller-based, software-defined architecture (overlay, underlay, fabric)",
        "6.4": "Explain AI and machine learning in network operations (agentic AI, GenAI, Predictive AI)",
        "6.5": "Describe characteristics of REST-based APIs (authentication types, CRUD, HTTP verbs, data encoding)",
        "6.6": "Recognize capabilities of configuration management mechanisms (Ansible, Terraform)",
        "6.7": "Recognize components of JSON-encoded data"
      }
    }
  },
